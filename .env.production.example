NODE_ENV=production
PORT=10000
HOST_PORT=4000
VITE_API_URL=/api

# Connexion Google OAuth
# Créer un identifiant client OAuth Web dans Google Cloud Console.
# GOOGLE_CLIENT_ID est vérifié par le backend ; VITE_GOOGLE_CLIENT_ID affiche le bouton côté frontend.
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=


# Domaine public Railway ou domaine personnalisé.
# Exemple Railway : https://votre-service.up.railway.app
FRONTEND_ORIGIN=https://votre-service.up.railway.app

# Persistance Railway.
# La base principale doit être PostgreSQL Railway via DATABASE_URL.
# DATA_DIR reste utile pour les médias/fichiers locaux ; montez un volume Railway sur /app/data si vous stockez des uploads.
DATA_DIR=/app/data
# Optionnel uniquement en développement local sans Postgres :
DATABASE_PATH=laccord_secret.sqlite

# Géolocalisation par ville (OpenStreetMap/Nominatim par défaut)
GEOCODER_URL=https://nominatim.openstreetmap.org/search
GEOCODER_COUNTRYCODES=fr,be,ch,lu,mc
GEOCODER_USER_AGENT=Voluptia/1.0 city-distance-geocoder
DISABLE_EXTERNAL_GEOCODING=false
# Suggestions de ville/code postal via geo.api.gouv.fr (France).
DISABLE_CITY_SUGGESTIONS=false


# Paiement Stripe. L'accès n'est activé qu'après confirmation via webhook signé.
# 1. Créez un compte Stripe et récupérez votre clé secrète (sk_live_... ou sk_test_...).
# 2. Dans Stripe → Developers → Webhooks, ajoutez un endpoint pointant vers :
#    https://votre-service.up.railway.app/api/payments/webhook
#    Événement à écouter : checkout.session.completed
#    Copiez le "Signing secret" (whsec_...) dans STRIPE_WEBHOOK_SECRET.
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYMENT_CURRENCY=eur
# URL publique de base utilisée pour les redirections de retour de paiement.
# Laisser vide pour réutiliser FRONTEND_ORIGIN. Sinon, surcharger explicitement :
PUBLIC_BASE_URL=https://votre-service.up.railway.app
# Optionnel : surcharge fine des pages de retour (sinon dérivées de PUBLIC_BASE_URL).
PAYMENT_SUCCESS_URL=
PAYMENT_CANCEL_URL=
ENABLE_DEMO_PAID_ACTIVATION=false
SEED_WELCOME_PROMO=false

# Pas de compte admin "de base". L'accès admin est accordé au propriétaire ci-dessous,
# qui devient admin dès qu'il crée son compte via l'inscription normale.
# Laisser ADMIN_EMAIL / ADMIN_INITIAL_PASSWORD vides.
ADMIN_EMAIL=
ADMIN_INITIAL_PASSWORD=


# Email propriétaire : tout compte créé avec cet email devient automatiquement admin.
# Renseigner votre email réel ici (dans les variables Railway, pas dans Git).
OWNER_ADMIN_EMAILS=admin@example.com
OWNER_ADMIN_INITIAL_PASSWORD=
ADMIN_BOOTSTRAP_EMAIL=
DISABLE_BOOTSTRAP_ADMIN=true

# Contrôle d'âge : par défaut, déclaration de majorité + acceptation CGU (traçabilité serveur).
# Pour brancher un prestataire de vérification renforcée plus tard :
#   AGE_VERIFICATION_ENABLED=true et AGE_VERIFICATION_PROVIDER=veriff (par ex.)
AGE_VERIFICATION_ENABLED=false
AGE_VERIFICATION_PROVIDER=
AGE_VERIFICATION_PROVIDER_URL=
AGE_VERIFICATION_WEBHOOK_SECRET=

# Staging privé seulement : autorise le provider demo même avec NODE_ENV=production.
ALLOW_DEMO_AGE_IN_PRODUCTION=false
TRUST_PROXY=1

# Sécurité : false = /api/health ne révèle pas les détails en production.
PUBLIC_PRODUCTION_HEALTH=false

# --- Emails ---
# Deux options, dans cet ordre de priorité : SMTP (o2switch) puis Resend.
# Sans configuration, l'app fonctionne en "mode log" (les emails s'affichent dans les logs).
#
# OPTION A — SMTP o2switch (recommandé pour vous, vous avez déjà une boîte mail o2switch) :
#   1. Dans le cPanel o2switch, créez une adresse (ex. noreply@votredomaine.fr) et notez son mot de passe.
#   2. SMTP_HOST est en général "mail.votredomaine.fr" (ou le serveur o2switch type
#      "xxx.o2switch.net" indiqué dans cPanel > Comptes de messagerie > Connecter les appareils).
#   3. Port 465 (SSL) recommandé, ou 587 (STARTTLS) avec SMTP_SECURE=false.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@votredomaine.fr
SMTP_PASS=
#
# OPTION B — Resend (alternative, si vous ne voulez pas utiliser o2switch pour l'envoi) :
RESEND_API_KEY=
#
# Adresse expéditrice (commune aux deux options). Avec o2switch, mettez votre adresse o2switch.
EMAIL_FROM=Voluptia <noreply@votredomaine.fr>

# --- Base de données Railway Postgres ---
# À configurer dans Railway > service web > Variables.
# Valeur recommandée : DATABASE_URL=${{Postgres.DATABASE_URL}}
# L'application accepte aussi POSTGRES_URL, mais DATABASE_URL est le standard Railway/PostgreSQL.
DATABASE_URL=
# En production Railway, laissez true pour empêcher un démarrage accidentel sur SQLite/JSON éphémère.
REQUIRE_DATABASE_URL=true

# --- Notifications push navigateur (Web Push) ---
# Optionnel : par defaut, les cles VAPID sont generees au premier demarrage et
# conservees en base. Pour les fixer explicitement : npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
