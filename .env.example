NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:4000,http://127.0.0.1:4000
VITE_API_URL=/api

# Connexion Google OAuth
# Créer un identifiant client OAuth Web dans Google Cloud Console.
# GOOGLE_CLIENT_ID est vérifié par le backend ; VITE_GOOGLE_CLIENT_ID affiche le bouton côté frontend.
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=


# Base de données locale
# Avec Node.js 22+, le projet utilise SQLite via node:sqlite.
DATA_DIR=data
DATABASE_PATH=laccord_secret.sqlite

# Géolocalisation par ville (OpenStreetMap/Nominatim par défaut)
GEOCODER_URL=https://nominatim.openstreetmap.org/search
GEOCODER_COUNTRYCODES=fr,be,ch,lu,mc
GEOCODER_USER_AGENT=Voluptia/1.0 city-distance-geocoder
DISABLE_EXTERNAL_GEOCODING=false
# Suggestions de ville/code postal via geo.api.gouv.fr (France).
DISABLE_CITY_SUGGESTIONS=false

# Contrôle d’âge
# Par défaut : déclaration de majorité + acceptation CGU (traçabilité serveur), sans prestataire.
# Pour brancher un prestataire de vérification renforcée plus tard, mettre AGE_VERIFICATION_ENABLED=true
# puis renseigner AGE_VERIFICATION_PROVIDER (ex. veriff) et AGE_VERIFICATION_PROVIDER_URL.
AGE_VERIFICATION_ENABLED=false
AGE_VERIFICATION_PROVIDER=
AGE_VERIFICATION_PROVIDER_URL=
REQUIRE_AGE_VERIFICATION=true

# Paiement Stripe Checkout (laisser vide en dev pour désactiver le paiement réel).
# En test : PAYMENT_PROVIDER=stripe + clés sk_test_... / whsec_...
# Webhook local (Stripe CLI) : stripe listen --forward-to localhost:4000/api/payments/webhook
PAYMENT_PROVIDER=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYMENT_CURRENCY=eur
PUBLIC_BASE_URL=http://localhost:4000
PAYMENT_SUCCESS_URL=
PAYMENT_CANCEL_URL=
ENABLE_DEMO_PAID_ACTIVATION=false
SEED_WELCOME_PROMO=true

# Admin local/dev. En production, définir des valeurs uniques et fortes.
ADMIN_EMAIL=
ADMIN_INITIAL_PASSWORD=
OWNER_ADMIN_EMAILS=
OWNER_ADMIN_INITIAL_PASSWORD=
ADMIN_BOOTSTRAP_EMAIL=
DISABLE_BOOTSTRAP_ADMIN=false

# --- Base de donnees ---
# PostgreSQL manage (recommande en production : durable, sauvegarde). Si defini, prime sur SQLite.
# Sur Render, injecte automatiquement depuis la base "voluptia-db" (render.yaml).
# Railway/PostgreSQL :
# DATABASE_URL=postgresql://user:password@host:5432/voluptia
# REQUIRE_DATABASE_URL=true

# --- Notifications push navigateur (Web Push) ---
# Optionnel : par defaut, les cles VAPID sont generees au premier demarrage et
# conservees en base. Pour les fixer explicitement : npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
